# ===== ①ネタ管理（Supabase）=====
# 未設定の場合は data/terms.seed.json をローカル用語マスタとして使用する
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===== ②台本生成（Gemini Flash・無料枠）=====
# 未設定の場合はテンプレート台本生成にフォールバックする
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===== ④音声合成（VOICEVOX）=====
# ローカルエンジンの URL。到達できない場合は無音WAVモックにフォールバックする
VOICEVOX_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER=3

# ===== ⑥配信: YouTube Data API v3 =====
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ===== ⑥配信: TikTok Content Posting API =====
TIKTOK_ACCESS_TOKEN=

# ===== ⑥配信: Instagram（Google Drive 経由）=====
# サービスアカウントJSONのパス、または GOOGLE_APPLICATION_CREDENTIALS を使用
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=
