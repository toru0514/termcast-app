# ===== ①ネタ管理（Supabase）=====
# 未設定の場合は data/terms.seed.json をローカル用語マスタとして使用する
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===== ②台本生成（Gemini Flash・無料枠）=====
# 未設定の場合はテンプレート台本生成にフォールバックする
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===== ③台本のファクトチェック・ゲート（独立AI検証）=====
# 生成した台本の事実誤り（例: 陰線の始値/終値の取り違え）を Gemini で検証し、
# 通らない用語は needs_review にして次の用語へ。GEMINI 未設定時は自動でスキップ（Noop）。
VERIFY_ENABLED=true
# 検証用モデル（未指定なら GEMINI_MODEL を流用）。将来 Pro 等へ差し替え可能。
# VERIFY_MODEL=gemini-2.5-flash
# fail 時の再生成回数の上限（既定2 = 最大3回生成）
# VERIFY_MAX_REGEN=2
# 1回の generate 実行で試す用語数の上限（fail が続いたら次の用語へ。既定3）
# VERIFY_MAX_TERMS=3

# ===== ④音声合成（VOICEVOX）=====
# ローカルエンジンの URL。到達できない場合は無音WAVモックにフォールバックする
VOICEVOX_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER=3

# ===== YouTube アップロード（YouTube Data API v3 / OAuth）=====
# 事前準備:
#   ① GCP で「YouTube Data API v3」を有効化
#   ② npm run youtube:auth を実行（gws の OAuth クライアントを流用して refresh token を取得し下に保存）
# YOUTUBE_UPLOAD=1 かつ YOUTUBE_REFRESH_TOKEN があれば generate 時に自動アップロード。
YOUTUBE_UPLOAD=
YOUTUBE_PRIVACY=public
YOUTUBE_CATEGORY_ID=27
YOUTUBE_REFRESH_TOKEN=
# OAuth クライアント(client_secret.json)のパス。未指定なら gws のものを流用。
YOUTUBE_CLIENT_SECRET_FILE=

# ===== SNS投稿自動化: TikTok Content Posting API =====
# 取得手順:
#   ① 開発者ポータル(Sandbox)で Client key / Client secret を下に設定
#   ② npm run tiktok:auth を実行 → ブラウザで承認 → コールバックページの code を貼り付け
#      → TIKTOK_ACCESS_TOKEN と TIKTOK_REFRESH_TOKEN が自動保存される
# 以降は実行時に refresh_token で access_token を自動更新（access_tokenは24時間で失効）。
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
# Redirect URI（未指定なら本リポジトリのGitHub Pagesコールバックを使用）。開発者ポータルの登録値と一致必須。
# TIKTOK_REDIRECT_URI=https://toru0514.github.io/termcast-app/callback.html
# スコープ（v2はカンマ区切り）。direct投稿を狙う場合は video.publish を追加（要アプリ審査）。
# TIKTOK_SCOPES=user.info.basic,video.upload
# inbox（審査不要・アプリ下書きへ送信）/ direct（審査後・プロフィールへ直接投稿）
TIKTOK_MODE=inbox

# ===== SNS投稿自動化: Instagram Graph API（審査通過後の本実装用）=====
# 未設定なら output/instagram/{content_id}/ に下書きJSONを生成するのみ（審査中の暫定運用）。
INSTAGRAM_IG_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# ===== SNS投稿自動化: X (Twitter) API v2 =====
# OAuth2 ユーザーコンテキストの Bearer（投稿権限つき）。
X_ACCESS_TOKEN=
# リンク付き投稿は 1件 $0.20 と高額。既定はリンクを含めない（プロフィール誘導のみ）。
X_INCLUDE_LINKS=
X_PROFILE_URL=

# ===== SNS投稿自動化: レート制限の上書き（任意 / 設計書 §5）=====
# SOCIAL_TIKTOK_RPM=6
# SOCIAL_TIKTOK_PER_DAY=15
# SOCIAL_INSTAGRAM_PER_DAY=100
# SOCIAL_X_CAPTION_MAX=280

# ===== Google Drive 保存（generate で自動保存 / Instagram用）=====
# 認証は gws CLI（keyring）が持つため、保存先フォルダID だけ設定すればよい。
# 設定すると generate の最後に自動で Drive へアップロードする。
GOOGLE_DRIVE_FOLDER_ID=
