# ===== ①ネタ管理（Supabase）=====
# 未設定の場合は data/terms.seed.json をローカル用語マスタとして使用する
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===== ②台本生成（Gemini Flash・無料枠）=====
# 未設定の場合はテンプレート台本生成にフォールバックする
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===== ④音声合成（VOICEVOX）=====
# ローカルエンジンの URL。到達できない場合は無音WAVモックにフォールバックする
VOICEVOX_URL=http://127.0.0.1:50021
VOICEVOX_SPEAKER=3

# ===== YouTube アップロード（YouTube Data API v3 / OAuth）=====
# 事前準備:
#   ① GCP で「YouTube Data API v3」を有効化
#   ② npm run youtube:auth を実行（gws の OAuth クライアントを流用して refresh token を取得し下に保存）
# YOUTUBE_UPLOAD=1 かつ YOUTUBE_REFRESH_TOKEN があれば generate 時に自動アップロード。
YOUTUBE_UPLOAD=
YOUTUBE_PRIVACY=public
YOUTUBE_CATEGORY_ID=27
YOUTUBE_REFRESH_TOKEN=
# OAuth クライアント(client_secret.json)のパス。未指定なら gws のものを流用。
YOUTUBE_CLIENT_SECRET_FILE=

# ===== SNS投稿自動化: TikTok Content Posting API =====
# video.upload スコープの user access_token。inbox 下書き送信は審査不要。
TIKTOK_ACCESS_TOKEN=
# inbox（審査不要・アプリ下書きへ送信）/ direct（審査後・プロフィールへ直接投稿）
TIKTOK_MODE=inbox

# ===== SNS投稿自動化: Instagram Graph API（審査通過後の本実装用）=====
# 未設定なら output/instagram/{content_id}/ に下書きJSONを生成するのみ（審査中の暫定運用）。
INSTAGRAM_IG_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# ===== SNS投稿自動化: X (Twitter) API v2 =====
# OAuth2 ユーザーコンテキストの Bearer（投稿権限つき）。
X_ACCESS_TOKEN=
# リンク付き投稿は 1件 $0.20 と高額。既定はリンクを含めない（プロフィール誘導のみ）。
X_INCLUDE_LINKS=
X_PROFILE_URL=

# ===== SNS投稿自動化: レート制限の上書き（任意 / 設計書 §5）=====
# SOCIAL_TIKTOK_RPM=6
# SOCIAL_TIKTOK_PER_DAY=15
# SOCIAL_INSTAGRAM_PER_DAY=100
# SOCIAL_X_CAPTION_MAX=280

# ===== Google Drive 保存（generate で自動保存 / Instagram用）=====
# 認証は gws CLI（keyring）が持つため、保存先フォルダID だけ設定すればよい。
# 設定すると generate の最後に自動で Drive へアップロードする。
GOOGLE_DRIVE_FOLDER_ID=
